{
	"name": "n8n-nodes-playwright-core",
	"version": "0.1.0",
	"description": "n8n community node for browser automation with Playwright Core browser agnostic",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"playwright",
		"playwright-core",
		"browserless",
		"browser automation"
	],
	"license": "MIT",
	"homepage": "https://github.com/IA-Generative/n8n-nodes-playwright-core",
	"author": {
		"name": "Killian Courvoisier",
		"email": "dev.killian.courvoisier@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IA-Generative/n8n-nodes-playwright-core"
	},
	"engines": {
		"node": ">=22.22.1",
		"pnpm": ">=9.1"
	},
	"packageManager": "pnpm@10.32.1",
	"main": "dist/nodes/index.js",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes package.json --write",
		"lint": "eslint nodes package.json",
		"lintfix": "eslint nodes package.json --fix"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/playwright/Playwright.node.js"
		]
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.10.1",
		"@typescript-eslint/parser": "^7.15.0",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.1",
		"gulp": "^4.0.2",
		"n8n-workflow": "*",
		"prettier": "^3.3.2",
		"typescript": "^5.5.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"@n8n/vm2": "^3.9.25",
		"fs-extra": "^11.2.0",
		"playwright-core": "1.58.2"
	}
}
